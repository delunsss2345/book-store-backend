model OrderItem {
  id      BigInt @id @default(autoincrement())
  orderId BigInt @map("order_id")

  bookVariantSnapshotId BigInt              @map("book_variant_snapshot_id")
  bookVariantSnapshot   BookVariantSnapshot @relation(fields: [bookVariantSnapshotId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(12, 2)
  lineTotal Decimal  @map("line_total") @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([bookVariantSnapshotId])
  @@index([orderId])
  @@map("order_items")
}

model Order {
  id             BigInt         @id @default(autoincrement())
  orderCode      String         @unique @map("order_code") @db.VarChar(50)
  userId         BigInt?        @map("user_id")
  addressId      BigInt?        @map("address_id")
  cartHash       String?        @unique @map("cart_hash")
  guestSessionId String?        @map("guest_session_id") @db.Char(36)
  guestEmail     String?        @map("guest_email") @db.VarChar(320)
  status         OrderStatus?
  paymentStatus  PaymentStatus? @map("payment_status")
  subtotal       Decimal?       @db.Decimal(12, 2)
  discountAmount Decimal?       @map("discount_amount") @db.Decimal(12, 2)
  shippingFee    Decimal?       @map("shipping_fee") @db.Decimal(12, 2)
  totalAmount    Decimal?       @map("total_amount") @db.Decimal(12, 2)
  currencyCode   String?        @map("currency_code") @db.VarChar(3)
  idempotencyKey String?        @unique @map("idempotency_key") @db.VarChar(100)
  note           String?        @db.Text
  placedAt       DateTime?      @map("placed_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  expiredAt      DateTime       @map("expired_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  createdBy      BigInt?        @map("created_by")
  updatedBy      BigInt?        @map("updated_by")

  // Relations
  user         User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestSession GuestSession?        @relation(fields: [guestSessionId], references: [id], onDelete: SetNull)
  creator      User?                @relation("OrderCreator", fields: [createdBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  updater      User?                @relation("OrderUpdater", fields: [updatedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  address      OrderAddress?
  items        OrderItem[]
  payments     PaymentTransaction[]
  addressUser  UserAddress?         @relation(fields: [addressId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paymentIntents PaymentIntent[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("orders")
}

model Cart {
  id             BigInt   @id @default(autoincrement())
  userId         BigInt?  @map("user_id")
  guestSessionId String?  @map("guest_session_id") @db.Char(36)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  guestSession GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  items        CartItem[]

  @@index([userId])
  @@index([guestSessionId])
  @@map("carts")
}

model Wishlist {
  id             BigInt    @id @default(autoincrement())
  userId         BigInt?   @map("user_id")
  guestSessionId String?   @map("guest_session_id") @db.Char(36)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deleteAt       DateTime? @map("delete_at")

  // Relations
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  guestSession GuestSession?  @relation(fields: [guestSessionId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  items        WishlistItem[]

  @@index([userId])
  @@index([guestSessionId])
  @@map("wishlists")
}

model WishlistItem {
  id            BigInt   @id @default(autoincrement())
  wishlistId    BigInt   @map("wishlist_id")
  bookVariantId BigInt   @map("book_variant_id")
  addedAt       DateTime @default(now()) @map("added_at")

  // Relations
  wishlist Wishlist    @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  variant  BookVariant @relation(fields: [bookVariantId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, bookVariantId])
  @@map("wishlist_items")
}

model CartItem {
  id            BigInt   @id @default(autoincrement())
  cartId        BigInt   @map("cart_id")
  bookVariantId BigInt   @map("book_variant_id")
  quantity      Int
  addedAt       DateTime @default(now()) @map("added_at")

  // Relations
  cart    Cart        @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant BookVariant @relation(fields: [bookVariantId], references: [id], onDelete: Cascade)

  @@unique([cartId, bookVariantId])
  @@map("cart_items")
}

model OrderAddress {
  id            BigInt  @id @default(autoincrement())
  orderId       BigInt  @unique @map("order_id")
  recipientName String  @map("recipient_name") @db.VarChar(200) // Nối lastname firstname
  phoneNumber   String  @map("phone_number") @db.VarChar(30)
  addressLine   String  @map("address_line") @db.VarChar(500)
  ward          String? @db.VarChar(200)
  district      String? @db.VarChar(200)
  city          String  @db.VarChar(200)
  countryCode   String? @map("country_code") @db.VarChar(2)
  note          String? @db.Text

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_addresses")
}

model PaymentTransaction {
  id      BigInt  @id @default(autoincrement())
  orderId BigInt  @map("order_id")
  userId  BigInt? @map("user_id")

  gateway PaymentGateway
  status  PaymentStatus?

  amount       Decimal @db.Decimal(12, 2)
  currencyCode String? @map("currency_code") @db.VarChar(3)

  providerTxnId   String? @map("provider_txn_id") @db.VarChar(200)
  referenceNumber String? @map("reference_number") @db.VarChar(200)
  requestId       String? @map("request_id") @db.VarChar(100)
  idempotencyKey  String? @map("idempotency_key") @db.VarChar(100)
  paymentUrl      String? @map("payment_url") @db.VarChar(100)
  requestPayload  Json?   @map("request_payload")
  responsePayload Json?   @map("response_payload")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([orderId, createdAt])
  @@index([gateway, providerTxnId])
  @@map("payment_transactions")
}


model PaymentIntent {
  id             String  @id @default(cuid())
  orderId        BigInt  @map("order_id")
  orderCode      String  @map("order_code") @db.VarChar(50)
  gateway        PaymentGateway
  status         PaymentStatus?
  tokenUrl       String @map("token_url") @unique @db.VarChar(200) // Dùng để lưu URL trả về token thanh toán từ cổng thanh toán
  paymentUrl      String? @map("payment_url") @db.VarChar(200) // URL để redirect người dùng đến trang thanh toán của cổng thanh toán
  expiredAt DateTime  @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([orderId, createdAt])
  @@index([orderId, gateway])
  @@map("payment_intents")  
}