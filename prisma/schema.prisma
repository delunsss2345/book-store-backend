generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum HTTPMethod {
  GET
  POST
  PUT
  DELETE
  PATCH
  OPTIONS
  HEAD
}

enum DevicePlatform {
  WEB
  ANDROID
  IOS
  DESKTOP
  OTHER
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum VerificationType {
  REGISTER
  FORGOT_PASSWORD
  CHANGE_EMAIL
}

enum BookFormat {
  HARDCOVER
  PAPERBACK
  EBOOK
  AUDIOBOOK
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CONFIRMED
  PACKING
  SHIPPING
  DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURNED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIAL_REFUND
}

enum PaymentGateway {
  COD
  VNPAY
  MOMO
  STRIPE
  PAYPAL
  OTHER
}

enum EmailStatus {
  PENDING
  SENDING
  SENT
  FAILED
  CANCELLED
}

enum JobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  CANCELLED
}

enum InventoryReason {
  PURCHASE
  RESTOCK
  ADJUSTMENT
  RETURN
}

enum ConsentType {
  ANALYTICS
  MARKETING
}

enum EventType {
  VIEW_BOOK
  SEARCH
  ADD_TO_CART
  REMOVE_FROM_CART
  CHECKOUT_START
  PLACE_ORDER
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  LOGIN
  LOGOUT
}

model User {
  id                BigInt      @id @default(autoincrement())
  username          String      @unique @db.VarChar(100)
  email             String      @unique @db.VarChar(255)
  phoneNumber       String?     @map("phone_number") @db.VarChar(30)
  firstName         String?     @map("first_name") @db.VarChar(100)
  lastName          String?     @map("last_name") @db.VarChar(100)
  gender            String?     @db.VarChar(20)
  avatarUrl         String?     @map("avatar_url") @db.VarChar(255)
  passwordHash      String      @map("password_hash") @db.VarChar(255)
  passwordChangedAt DateTime?   @map("password_changed_at")
  isEmailVerified   Boolean     @default(false) @map("is_email_verified")
  totpSecret        String?     @map("totp_secret") @db.VarChar(255)
  verifyEmailAt     DateTime?   @map("verify_email_at")

  status            UserStatus  @default(ACTIVE)
  lastLoginAt       DateTime?   @map("last_login_at")

  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  deletedAt         DateTime?   @map("deleted_at")
  createdBy         BigInt?     @map("created_by")
  updatedBy         BigInt?     @map("updated_by")

  userRoles         UserRole[]
  createdPermissions          Permission[] @relation("PermissionCreatedBy")
  updatedPermissions          Permission[] @relation("PermissionUpdatedBy")
  createdRoles          Role[] @relation("RoleCreatedBy") 
  updatedRoles          Role[] @relation("RoleUpdatedBy")
  
  @@map("users")
}

model Role {
  id          BigInt   @id @default(autoincrement())
  code        String   @map("code") @db.VarChar(255)
  name        String   @map("name") @db.VarChar(255)
  description String   @db.VarChar(255)
  isActive    Boolean  @map("is_active")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  createById  BigInt?   @map("created_by_id") 
  updateById  BigInt?   @map("updated_by_id")

  deletedBy   BigInt?  @map("deleted_by")


  userRoles   UserRole[]
  roles       RolePermission[]

  createdBy   User?  @relation("RoleCreatedBy" , fields: [createById] , references: [id] , onDelete: SetNull , onUpdate: NoAction)
  updatedBy   User?  @relation("RoleUpdatedBy" , fields: [updateById] , references: [id] , onDelete: SetNull , onUpdate: NoAction)


  @@map("roles")
}

model UserRole {
  userId    BigInt  @map("user_id")
  roleId    BigInt  @map("role_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  createdBy BigInt? @map("created_by")
  updatedBy BigInt? @map("updated_by")
  deletedBy BigInt? @map("deleted_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_role")
}

model Permission {
  id          BigInt     @id @default(autoincrement())
  code        String?    @unique @db.VarChar(100)
  description String?    @db.Text
  method      HTTPMethod
  pathPattern String     @map("path_pattern") @db.VarChar(500)
  isActive    Boolean    @default(true) @map("is_active")

  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  deletedAt   DateTime?  @map("deleted_at")

  createdById BigInt?       @map("created_by_id")
  updatedById BigInt?       @map("update_by_id")

  createdBy   User?    @relation("PermissionCreatedBy" , fields: [createdById] , references: [id], onDelete: SetNull,onUpdate: NoAction)
  updatedBy   User?    @relation("PermissionUpdatedBy" , fields: [updatedById] , references: [id], onDelete: SetNull , onUpdate: NoAction)

  roles       RolePermission[]

  @@unique([method, pathPattern])
  @@map("permissions")
}

model RolePermission {
  roleId       BigInt @map("role_id")
  permissionId BigInt @map("permission_id")
  
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}
