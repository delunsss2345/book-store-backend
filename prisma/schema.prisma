// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id          BigInt   @id @default(autoincrement())
  firstName   String?  @map("first_name")   @db.VarChar(255)
  lastName    String?  @map("last_name")    @db.VarChar(255)
  gender      String?  @map("gender")       @db.VarChar(255)
  email       String?  @map("email")        @db.VarChar(255)
  phoneNumber String?  @map("phone_number") @db.VarChar(255)
  isActive    Boolean? @map("is_active")
  username    String?  @map("username")     @db.VarChar(255)
  password    String?  @map("password")     @db.VarChar(255)
  createAt DateTime @map("create_at") 
  updateAt DateTime @map("update_at")

  userRoles   UserRole[]

  @@map("users")
}

model Role {
  id        BigInt  @id @default(autoincrement())
  code      String? @map("code") @db.VarChar(255)
  name      String? @map("name") @db.VarChar(255)

  userRoles UserRole[]
  createAt DateTime @map("create_at") 
  updateAt DateTime @map("update_at")
  @@map("roles")
}

model UserRole {
  userId BigInt @map("user_id")
  roleId BigInt @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createAt DateTime @map("create_at") 
  updateAt DateTime @map("update_at")
  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_role")
}


model Book {
  id              BigInt   @id @default(autoincrement())
  varantId        BigInt?  @map("varant_id")

  title           String?  @map("title")            @db.VarChar(255)
  author          String?  @map("author")           @db.VarChar(255)
  description     String?  @map("description")      @db.Text
  slug            String                            @unique
  publicationYear Int?     @map("publication_year")
  weightGrams     Int?     @map("weight_grams")
  pageCount       Int?     @map("page_count")

  format          String?  @map("format")           @db.VarChar(255)

  price           Float?   @map("price")
  quantity        Int?     @map("quantity")

  imageUrl        String?  @map("image_url")        @db.VarChar(500)

  isActive        Boolean? @map("is_active")

  createdAt       DateTime? @map("created_at")
  updatedAt       DateTime? @map("updated_at")

  @@map("books")
}
