generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum HTTPMethod {
  GET
  POST
  PUT
  DELETE
  PATCH
  OPTIONS
  HEAD
}

enum DevicePlatform {
  WEB
  ANDROID
  IOS
  DESKTOP
  OTHER
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum VerificationType {
  REGISTER
  FORGOT_PASSWORD
  CHANGE_EMAIL
}

enum BookFormat {
  HARDCOVER
  PAPERBACK
  EBOOK
  AUDIOBOOK
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  CONFIRMED
  PACKING
  SHIPPING
  DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURNED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
  PARTIAL_REFUND
}

enum PaymentGateway {
  COD
  VNPAY
  MOMO
  STRIPE
  PAYPAL
  OTHER
}

enum EmailStatus {
  PENDING
  SENDING
  SENT
  FAILED
  CANCELLED
}

enum JobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
  CANCELLED
}

enum InventoryReason {
  PURCHASE
  RESTOCK
  ADJUSTMENT
  RETURN
}

enum ConsentType {
  ANALYTICS
  MARKETING
}

enum EventType {
  VIEW_BOOK
  SEARCH
  ADD_TO_CART
  REMOVE_FROM_CART
  CHECKOUT_START
  PLACE_ORDER
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  LOGIN
  LOGOUT
}

enum RoleCode {
  GUEST 
  ADMIN
  STAFF 
  CUSTOMER 
  WAREHOUSE
}

model User {
  id                BigInt    @id @default(autoincrement())
  email             String    @unique @db.VarChar(255)
  phoneNumber       String?   @map("phone_number") @db.VarChar(30)
  firstName         String?   @map("first_name") @db.VarChar(100)
  lastName          String?   @map("last_name") @db.VarChar(100)
  gender            String?   @db.VarChar(20)
  avatarUrl         String?   @map("avatar_url") @db.VarChar(255)
  password          String    @map("password") @db.VarChar(255)
  passwordChangedAt DateTime? @map("password_changed_at")
  isEmailVerified   Boolean   @default(false) @map("is_email_verified")
  totpSecret        String?   @map("totp_secret") @db.VarChar(255)
  verifyEmailAt     DateTime? @map("verify_email_at")

  status      UserStatus @default(ACTIVE)
  lastLoginAt DateTime?  @map("last_login_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  userRoles UserRole[]

  userDevices        UserDevice[]
  loginAttempts      LoginAttempt[]
  verificationCodes  VerificationCode[]
  createdPermissions Permission[]       @relation("PermissionCreatedBy")
  updatedPermissions Permission[]       @relation("PermissionUpdatedBy")
  createdRoles       Role[]             @relation("RoleCreatedBy")
  updatedRoles       Role[]             @relation("RoleUpdatedBy")
  userSessions       UserSession[]
  // userAddress        UserAddress[]


  @@map("users")
}

model Role {
  id          BigInt  @id @default(autoincrement())
  code        RoleCode  @map("code") @unique
  name        String  @map("name") @db.VarChar(255) @unique
  description String?  @db.VarChar(255)
  isActive    Boolean @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  createById BigInt? @map("created_by_id")
  updateById BigInt? @map("updated_by_id")

  deletedBy BigInt? @map("deleted_by")

  userRoles UserRole[]
  roles     RolePermission[]

  createdBy User? @relation("RoleCreatedBy", fields: [createById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy User? @relation("RoleUpdatedBy", fields: [updateById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@map("roles")
}

model UserRole {
  userId BigInt @map("user_id")
  roleId BigInt @map("role_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  createdBy BigInt? @map("created_by")
  updatedBy BigInt? @map("updated_by")
  deletedBy BigInt? @map("deleted_by")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model Permission {
  id          BigInt     @id @default(autoincrement())
  code        String?    @unique @db.VarChar(100)
  description String?    @db.Text
  method      HTTPMethod
  pathPattern String     @map("path_pattern") @db.VarChar(500)
  isActive    Boolean    @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  createdById BigInt? @map("created_by_id")
  updatedById BigInt? @map("updated_by_id")

  createdBy User? @relation("PermissionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  updatedBy User? @relation("PermissionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull, onUpdate: NoAction)

  roles RolePermission[]

  @@unique([method, pathPattern])
  @@map("permissions")
}

model RolePermission {
  roleId       BigInt @map("role_id")
  permissionId BigInt @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model VerificationCode {
  id        BigInt           @id @default(autoincrement())
  userId    BigInt?          @map("user_id")
  email     String?          @db.VarChar(200)
  type      VerificationType
  codeHash  String?           @map("code_hash") @db.VarChar(200)
  expiresAt DateTime         @map("expires_at")
  usedAt    DateTime?        @map("used_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, type])
  @@map("verification_codes")
}

model EmailOutbox {
  id          BigInt       @id @default(autoincrement())
  toEmail     String       @map("to_email") @db.VarChar(320)
  toName      String?      @map("to_name") @db.VarChar(200)
  subject     String?      @db.VarChar(500)
  templateKey String?      @map("template_key") @db.VarChar(200)
  status      EmailStatus?
  scheduledAt DateTime?    @map("scheduled_at")
  sentAt      DateTime?    @map("sent_at")
  attempts    Int?
  lastError   String?      @map("last_error") @db.Text
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([status, scheduledAt])
  @@map("email_outbox")
}

model LoginAttempt {
  id              BigInt   @id @default(autoincrement())
  userId          BigInt?  @map("user_id")
  ip              String?  @db.VarChar(64)
  userAgent       String?  @map("user_agent") @db.VarChar(1000)
  success         Boolean?
  failureReason   String?  @map("failure_reason") @db.VarChar(500)
  createdAt       DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("login_attempts")
}

model UserDevice {
  id                BigInt          @id @default(autoincrement())
  userId            BigInt          @map("user_id")
  deviceFingerprint String          @map("device_fingerprint") @db.VarChar(255) // FE gửi chuỗi ngẫu nhiên hoặc BE tự tạo, đây là id của thiết bị
  deviceName        String?         @map("device_name") @db.VarChar(200) //  Tên thiết bị
  platform          DevicePlatform? //Nền tảng thiết bị
  osVersion         String?         @map("os_version") @db.VarChar(50) // Phiên bản hệ điều hành
  appVersion        String?         @map("app_version") @db.VarChar(50) // Phiên bản ứng dụng
  isTrusted         Boolean         @default(false) @map("is_trusted") // Có tin tưởng thiết bị này không
  firstSeenAt       DateTime?       @map("first_seen_at") // Gửi lần đầu tiên
  lastSeenAt        DateTime?       @map("last_seen_at") // Lần cuối cùng zô
  revokedAt         DateTime?       @map("revoked_at") // Đã bị chặn khi nào 

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions UserSession[]

  @@unique([userId, deviceFingerprint])
  @@map("user_devices")
}

model UserSession {
  id               String         @id @default(uuid()) @db.Char(36)
  userId           BigInt         @map("user_id")
  deviceId         BigInt?        @map("device_id")
  status           SessionStatus  @default(ACTIVE)
  refreshTokenHash String         @unique @map("refresh_token_hash") @db.VarChar(255)
  userAgent        String?        @map("user_agent") @db.VarChar(150)
  createdAt        DateTime       @default(now()) @map("created_at")
  expiresAt        DateTime?      @map("expires_at")
  revokedAt        DateTime?      @map("revoked_at")

  // Relations
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  device UserDevice? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([deviceId, status])
  @@map("user_sessions")
}

model RevokedToken {
  id        String   @id @default(uuid()) @db.Char(36)
  tokenHash String   @unique @map("token_hash") @db.VarChar(150)

  revokedAt DateTime @default(now()) @map("revoked_at")
  expiresAt DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  @@index([expiresAt])
  @@map("revoked_tokens")
}


