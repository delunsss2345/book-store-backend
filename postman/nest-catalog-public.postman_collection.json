{
  "info": {
    "_postman_id": "5d193d3d-98cf-46be-a9ef-c8d3f9b2b2aa",
    "name": "Nest Catalog Public",
    "description": "Public catalog read endpoints for fast book rendering.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET Catalog Home",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/catalog/home?lang={{lang}}&limit=12"
        }
      }
    },
    {
      "name": "GET Books List",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/catalog/books?lang={{lang}}&page=1&limit=20&sort=newest"
        }
      }
    },
    {
      "name": "GET Book Detail",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/catalog/books/{{bookId}}?lang={{lang}}"
        }
      }
    },
    {
      "name": "GET Categories",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/catalog/categories?lang={{lang}}"
        }
      }
    },
    {
      "name": "GET Books By Category",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/catalog/categories/{{categoryId}}/books?lang={{lang}}&page=1&limit=20&sort=newest"
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "lang",
      "value": "vi"
    },
    {
      "key": "bookId",
      "value": "1"
    },
    {
      "key": "categoryId",
      "value": "1"
    }
  ]
}
