model EmailOutbox {
  id          BigInt       @id @default(autoincrement())
  toEmail     String       @map("to_email") @db.VarChar(320)
  toName      String?      @map("to_name") @db.VarChar(200)
  subject     String?      @db.VarChar(500)
  templateKey String?      @map("template_key") @db.VarChar(200)
  status      EmailStatus?
  scheduledAt DateTime?    @map("scheduled_at")
  sentAt      DateTime?    @map("sent_at")
  attempts    Int?
  lastError   String?      @map("last_error") @db.Text
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  payload     Json?        @map("payload")
  @@index([status, scheduledAt])
  @@map("email_outbox")
}

model WebhookInbox {
  id      BigInt         @id @default(autoincrement())
  gateway PaymentGateway

  providerEventId String   @map("provider_event_id") @db.VarChar(200)
  receivedAt      DateTime @map("received_at")
  payload         Json

  processedAt DateTime?  @map("processed_at")
  status      JobStatus?
  attempts    Int?
  lastError   String?    @map("last_error") @db.Text

  @@unique([gateway, providerEventId])
  @@map("webhook_inbox")
}
